# optional
MAIL_FORCE_TO=
MAIL_FORCE_CC=

PASSPORT_EXPIRY_WARNING_MONTHS=9
VISA_EXPIRY_WARNING_MONTHS=6
REENTRY_PERMIT_EXPIRY_WARNING_MONTHS=6

REQUESTLIST_PRES_OVERRIDE_ENABLED=true
REQUESTLIST_PRES_OVERRIDE_IDS=

EMAIL_ENABLED=true
EMAIL_MODE=redirect

MAIL_FROM_ADDRESS=
